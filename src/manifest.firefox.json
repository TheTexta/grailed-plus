{
  "manifest_version": 3,
  "name": "Grailed Plus",
  "version": "2.0.0.1",
  "description": "Price history and listing insights for grailed.com.",
  "icons": {
    "48": "icons/grailed-48.png",
    "96": "icons/grailed-96.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "{f68ae042-4fad-4e1e-8973-49c8348058ed}"
    }
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*.grailed.com/listings/*",
    "https://api.frankfurter.app/*"
  ],
  "action": {
    "default_title": "Grailed Plus",
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.grailed.com/listings/*"
      ],
      "js": [
        "priceHistory.js"
      ],
      "css": [
        "priceHistory.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
