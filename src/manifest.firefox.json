{
  "manifest_version": 3,
  "name": "Grailed Plus",
  "version": "2.0.0.1",
  "description": "Price history and listing insights for grailed.com.",
  "icons": {
    "48": "icons/grailed-48.png",
    "96": "icons/grailed-96.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "{f68ae042-4fad-4e1e-8973-49c8348058ed}"
    }
  },
  "host_permissions": [
    "*://*.grailed.com/listings/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.grailed.com/listings/*"
      ],
      "js": [
        "priceHistory.js"
      ],
      "css": [
        "priceHistory.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
