{
  "manifest_version": 3,
  "name": "Grailed Plus",
  "version": "2.1.0.0",
  "description": "Listing insights, currency conversion, and dark mode for grailed.com.",
  "icons": {
    "64": "icons/Logo0.5x.png",
    "128": "icons/Logo1x.png",
    "256": "icons/Logo2x.png",
    "512": "icons/Logo4x.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "{f68ae042-4fad-4e1e-8973-49c8348058ed}"
    }
  },
  "permissions": [
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://api.frankfurter.app/latest*",
    "https://www.depop.com/search/*",
    "https://www.depop.com/api/v3/search/*"
  ],
  "action": {
    "default_title": "Grailed Plus",
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.grailed.com/*"
      ],
      "js": [
        "contentScript.js"
      ],
      "css": [
        "contentScript.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
