{
  "name": "grailed-plus",
  "version": "2.1.0-beta.0",
  "private": true,
  "description": "Chrome-first MV3 beta for Grailed Plus",
  "dependencies": {
    "d3": "^7.9.0"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "playwright": "^1.53.2",
    "typescript": "^5.9.2"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "npm run build && node --test tests/*.test.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "node scripts/lint.mjs",
    "zip:chrome": "npm run build && node scripts/zip-chrome.mjs",
    "release:chrome": "npm run lint && npm run test && npm run zip:chrome",
    "e2e:live:grailed": "npm run build && node scripts/live-test-grailed.mjs"
  }
}
